set(CPACK_GENERATOR "NSIS")
set(CPACK_MONOLITHIC_INSTALL ON)
set(CPACK_PACKAGE_NAME "@PACKAGE_NAME@")
set(CPACK_PACKAGE_VENDOR "@PACKAGE_NAME@")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "@PACKAGE_NAME@")
set(CPACK_PACKAGE_INSTALL_REGISTRY_KEY "@PACKAGE_NAME@")
set(CPACK_PACKAGE_VERSION "@PACKAGE_VERSION@")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "OKILTV Windows build")
set(CPACK_PACKAGE_DESCRIPTION "OKILTV Windows build")
set(CPACK_PACKAGE_FILE_NAME "@PACKAGE_FILE_NAME@")
set(CPACK_OUTPUT_FILE_PREFIX "@OUTPUT_DIR@")
set(CPACK_RESOURCE_FILE_LICENSE "@LICENSE_FILE@")
set(CPACK_INSTALLED_DIRECTORIES "@STAGE_ROOT@" "/")
set(CPACK_NSIS_DISPLAY_NAME "@PACKAGE_NAME@")
set(CPACK_NSIS_PACKAGE_NAME "@PACKAGE_NAME@")
set(CPACK_NSIS_INSTALL_ROOT "$PROGRAMFILES64")
set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
set(CPACK_NSIS_MODIFY_PATH OFF)
set(CPACK_NSIS_EXTRA_INSTALL_COMMANDS "
  MessageBox MB_YESNO|MB_ICONQUESTION \"Create a shortcut on the Desktop?\" IDNO NoDesktopShortcut
    CreateShortCut \"$DESKTOP\\@PACKAGE_NAME@.lnk\" \"$INSTDIR\\@PACKAGE_NAME@.exe\"
  NoDesktopShortcut:
")
set(CPACK_NSIS_EXTRA_UNINSTALL_COMMANDS "
  Delete \"$DESKTOP\\@PACKAGE_NAME@.lnk\"
")
